# Environment Configuration for Multi-Index Agentic Retrieval Demo
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit your .env file with real credentials to source control

# ============================================================================
# Azure AI Search Configuration
# ============================================================================
# Your Azure AI Search service endpoint
# Format: https://YOUR-SEARCH-SERVICE-NAME.search.windows.net
SEARCH_ENDPOINT=https://your-search-service.search.windows.net

# ============================================================================
# AI Model Configuration (Azure OpenAI or Microsoft Foundry)
# ============================================================================
# Your AI model service endpoint - supports both formats:
#   - Azure OpenAI: https://YOUR-OPENAI-SERVICE-NAME.openai.azure.com
#   - Microsoft Foundry: https://YOUR-PROJECT-NAME.api.azureml.ms
# The SDK automatically detects and handles both endpoint types
AOAI_ENDPOINT=https://your-openai-service.openai.azure.com

# Azure OpenAI API version (use the latest stable version)
AOAI_API_VERSION=2024-10-21

# Embedding model configuration
# Model name for text embeddings (e.g., text-embedding-3-large, text-embedding-ada-002)
AOAI_EMBEDDING_MODEL=text-embedding-3-large

# Deployment name for your embedding model in Azure OpenAI
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Chat/GPT model configuration
# Model name for chat completions (e.g., gpt-4, gpt-4-turbo, gpt-35-turbo)
AOAI_GPT_MODEL=gpt-4

# Deployment name for your GPT model in Azure OpenAI
AOAI_GPT_DEPLOYMENT=gpt-4

# ============================================================================
# Multi-Index Configuration (Optional - defaults provided in notebook)
# ============================================================================
# Names for the two search indexes
# Defaults: index-earth-1, index-earth-2
INDEX_NAME_1=index-earth-1
INDEX_NAME_2=index-earth-2

# Names for the two knowledge sources
# Defaults: earth-ks-1, earth-ks-2
KNOWLEDGE_SOURCE_NAME_1=earth-ks-1
KNOWLEDGE_SOURCE_NAME_2=earth-ks-2

# Name for the knowledge base
# Default: earth-multi-kb
KNOWLEDGE_BASE_NAME=earth-multi-kb

# ============================================================================
# Authentication
# ============================================================================
# This demo uses DefaultAzureCredential which supports multiple authentication methods:
# 1. Environment variables (AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_CLIENT_SECRET)
# 2. Managed Identity (when running in Azure)
# 3. Azure CLI (run 'az login' before running the notebook)
# 4. Visual Studio Code (sign in to Azure through VS Code)
# 5. Azure PowerShell (run 'Connect-AzAccount' before running the notebook)

# For service principal authentication, uncomment and fill these:
# AZURE_CLIENT_ID=your-client-id
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_SECRET=your-client-secret

# ============================================================================
# Optional: Microsoft Foundry Configuration (for evaluation)
# ============================================================================
# Only needed if you want to run the evaluation section
# FOUNDRY_ENDPOINT=https://your-foundry-project.api.azureml.ms
